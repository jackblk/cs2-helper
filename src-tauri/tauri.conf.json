{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "CS2 Helper",
	"version": "0.3.0",
	"identifier": "com.jackblk.cs2-helper",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "CS2 Helper",
				"width": 800,
				"height": 910,
				"minWidth": 720,
				"minHeight": 560,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": [
			"nsis"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}